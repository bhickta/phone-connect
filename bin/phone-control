#!/usr/bin/env bash
set -euo pipefail

APP_NAME="phone-control"

usage() {
  cat <<'USAGE'
phone-control: control an Android phone from this PC using adb and scrcpy

Usage:
  phone-control doctor
  phone-control devices
  phone-control mirror [--no-audio] [--stay-awake] [--turn-screen-off]
  phone-control mirror-off [--no-audio]
  phone-control start [--screen-off] [--no-audio] [--stay-awake]
  phone-control start-off [--no-audio]
  phone-control sessions
  phone-control stop SESSION_ID_OR_PID
  phone-control stop-all
  phone-control logs SESSION_ID_OR_PID
  phone-control wireless-pair-qr
  phone-control wireless-pair HOST:PAIR_PORT PAIR_CODE
  phone-control wireless-connect HOST:ADB_PORT
  phone-control screenshot [OUT.png]
  phone-control record [OUT.mp4]
  phone-control install APK
  phone-control push SRC PHONE_DEST
  phone-control pull PHONE_SRC DEST
  phone-control apps
  phone-control open PACKAGE
  phone-control key KEYCODE_OR_NAME
  phone-control shell -- COMMAND...

Common key names:
  home back recent power volume-up volume-down enter

Examples:
  phone-control doctor
  phone-control mirror --stay-awake
  phone-control mirror-off
  phone-control start-off
  phone-control sessions
  phone-control stop phone-20260619-120000
  phone-control wireless-pair-qr
  phone-control wireless-pair 192.168.1.25:37123 123456
  phone-control wireless-connect 192.168.1.25:5555
  phone-control screenshot ~/Pictures/phone.png
USAGE
}

die() {
  printf '%s: %s\n' "$APP_NAME" "$*" >&2
  exit 1
}

state_dir() {
  if [ -n "${XDG_STATE_HOME:-}" ]; then
    printf '%s/phone-control\n' "$XDG_STATE_HOME"
  else
    printf '%s/.local/state/phone-control\n' "$HOME"
  fi
}

sessions_file() {
  printf '%s/sessions.tsv\n' "$(state_dir)"
}

logs_dir() {
  printf '%s/logs\n' "$(state_dir)"
}

screen_timeout_file() {
  printf '%s/original-screen-timeout\n' "$(state_dir)"
}

ensure_state() {
  mkdir -p "$(state_dir)" "$(logs_dir)"
  touch "$(sessions_file)"
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1"
}

need_adb() {
  need_cmd adb
}

need_scrcpy() {
  need_cmd scrcpy
}

random_hex() {
  local bytes="$1"
  od -An -N "$bytes" -tx1 /dev/urandom | tr -d ' \n'
}

mdns_endpoint() {
  local service_name="$1"
  local service_type="$2"
  local endpoint avahi_type avahi_output

  endpoint="$(adb mdns services 2>/dev/null | awk -v name="$service_name" -v type="$service_type" '
    $1 == name && $2 ~ type { print $3; exit }
  ')"
  if [ -n "$endpoint" ]; then
    printf '%s\n' "$endpoint"
    return 0
  fi

  command -v avahi-browse >/dev/null 2>&1 || return 0
  case "$service_type" in
    *pairing*) avahi_type="_adb-tls-pairing._tcp" ;;
    *connect*) avahi_type="_adb-tls-connect._tcp" ;;
    *) return 0 ;;
  esac

  avahi_output="$(timeout 2 avahi-browse -rtp "$avahi_type" 2>/dev/null || true)"
  awk -F ';' -v name="$service_name" -v type="$avahi_type" '
    $1 == "=" && $4 == name && $5 == type && $8 != "" && $9 != "" {
      print $8 ":" $9
      exit
    }
  ' <<< "$avahi_output"
}

mdns_connect_endpoint_for_host() {
  local host="$1"
  local endpoint avahi_output

  endpoint="$(adb mdns services 2>/dev/null | awk -v host="$host" '
    $2 ~ /_adb-tls-connect[.]_tcp/ && index($3, host ":") == 1 { print $3; exit }
  ')"
  if [ -n "$endpoint" ]; then
    printf '%s\n' "$endpoint"
    return 0
  fi

  command -v avahi-browse >/dev/null 2>&1 || return 0
  avahi_output="$(timeout 2 avahi-browse -rtp _adb-tls-connect._tcp 2>/dev/null || true)"
  awk -F ';' -v host="$host" '
    $1 == "=" && $5 == "_adb-tls-connect._tcp" && $8 == host && $9 != "" {
      print $8 ":" $9
      exit
    }
  ' <<< "$avahi_output"
}

wireless_pair_qr() {
  need_adb
  need_cmd qrencode

  local service_name password payload endpoint host connect_endpoint
  local deadline pair_output pair_status
  service_name="studio-$(random_hex 5)"
  password="$(random_hex 8)"
  payload="WIFI:T:ADB;S:${service_name};P:${password};;"

  printf 'On the phone, open Wireless debugging -> Pair device with QR code.\n'
  printf 'Scan this QR code within 120 seconds:\n\n'
  qrencode -t ANSIUTF8 -m 2 "$payload"
  printf '\nWaiting for the phone...\n'

  deadline=$((SECONDS + 120))
  endpoint=""
  while [ "$SECONDS" -lt "$deadline" ]; do
    endpoint="$(mdns_endpoint "$service_name" '_adb-tls-pairing[.]_tcp')"
    [ -n "$endpoint" ] && break
    sleep 1
  done

  [ -n "$endpoint" ] || die "QR pairing timed out. Confirm both devices are on the same Wi-Fi and client isolation is disabled."

  printf 'Pairing with %s...\n' "$endpoint"
  if pair_output="$(adb pair "$endpoint" "$password" 2>&1)"; then
    pair_status=0
  else
    pair_status=$?
  fi
  printf '%s\n' "$pair_output"
  if [ "$pair_status" -ne 0 ] || ! grep -q '^Successfully paired' <<< "$pair_output"; then
    die "the phone was discovered, but ADB could not reach its pairing port. Disable AP/client isolation or use another Wi-Fi network."
  fi

  host="${endpoint%:*}"
  deadline=$((SECONDS + 20))
  connect_endpoint=""
  while [ "$SECONDS" -lt "$deadline" ]; do
    connect_endpoint="$(mdns_connect_endpoint_for_host "$host")"
    [ -n "$connect_endpoint" ] && break
    sleep 1
  done

  if [ -n "$connect_endpoint" ]; then
    adb connect "$connect_endpoint"
  else
    printf 'Paired successfully. ADB did not discover the connection port; use wireless-connect with the port shown on the phone.\n'
  fi
}

require_device() {
  need_adb
  local count
  count="$(adb devices | awk 'NR > 1 && $2 == "device" { count++ } END { print count + 0 }')"
  if [ "$count" -eq 0 ]; then
    die "no authorized Android device found. Enable USB debugging, connect USB, and accept the phone prompt."
  fi
}

current_device() {
  adb devices | awk 'NR > 1 && $2 == "device" { print $1; exit }'
}

pid_alive() {
  kill -0 "$1" >/dev/null 2>&1
}

set_device_stay_awake() {
  local value="$1"
  adb shell svc power stayon "$value" >/dev/null 2>&1 || true
}

enable_screen_off_mode() {
  ensure_state

  if [ ! -f "$(screen_timeout_file)" ]; then
    adb shell settings get system screen_off_timeout > "$(screen_timeout_file)"
  fi

  set_device_stay_awake true
  adb shell settings put system screen_off_timeout 2147483647
}

disable_screen_off_mode() {
  local timeout_file original_timeout
  timeout_file="$(screen_timeout_file)"

  set_device_stay_awake false

  if [ -f "$timeout_file" ]; then
    original_timeout="$(tr -d '\r\n' < "$timeout_file")"
    if [ -n "$original_timeout" ] && [ "$original_timeout" != "null" ]; then
      adb shell settings put system screen_off_timeout "$original_timeout" >/dev/null 2>&1 || true
    else
      adb shell settings delete system screen_off_timeout >/dev/null 2>&1 || true
    fi
    rm -f "$timeout_file"
  fi
}

has_screen_off_session() {
  local file
  file="$(sessions_file)"
  [ -f "$file" ] || return 1

  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    if [ "$mode" = "screen-off" ]; then
      return 0
    fi
  done < "$file"

  return 1
}

cleanup_sessions() {
  ensure_state
  local file tmp
  local removed_screen_off=0
  file="$(sessions_file)"
  tmp="${file}.tmp"

  : > "$tmp"
  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    if pid_alive "$pid"; then
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$pid" "$mode" "$device" "$started" "$log_path" >> "$tmp"
    elif [ "$mode" = "screen-off" ]; then
      removed_screen_off=1
    fi
  done < "$file"
  mv "$tmp" "$file"

  if [ "$removed_screen_off" -eq 1 ] && ! has_screen_off_session; then
    disable_screen_off_mode
  fi
}

find_session() {
  local wanted="$1"
  cleanup_sessions

  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    if [ "$wanted" = "$id" ] || [ "$wanted" = "$pid" ]; then
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$pid" "$mode" "$device" "$started" "$log_path"
      return 0
    fi
  done < "$(sessions_file)"

  return 1
}

remove_session() {
  local wanted="$1"
  local file tmp
  file="$(sessions_file)"
  tmp="${file}.tmp"

  : > "$tmp"
  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    if [ "$wanted" = "$id" ] || [ "$wanted" = "$pid" ]; then
      continue
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$pid" "$mode" "$device" "$started" "$log_path" >> "$tmp"
  done < "$file"
  mv "$tmp" "$file"
}

keycode() {
  case "${1,,}" in
    home) printf 'KEYCODE_HOME\n' ;;
    back) printf 'KEYCODE_BACK\n' ;;
    recent|recents|overview) printf 'KEYCODE_APP_SWITCH\n' ;;
    power) printf 'KEYCODE_POWER\n' ;;
    volume-up|vol-up) printf 'KEYCODE_VOLUME_UP\n' ;;
    volume-down|vol-down) printf 'KEYCODE_VOLUME_DOWN\n' ;;
    enter) printf 'KEYCODE_ENTER\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

doctor() {
  local failed=0

  if command -v adb >/dev/null 2>&1; then
    printf 'adb: %s\n' "$(command -v adb)"
  else
    printf 'adb: missing\n'
    failed=1
  fi

  if command -v scrcpy >/dev/null 2>&1; then
    printf 'scrcpy: %s\n' "$(command -v scrcpy)"
  else
    printf 'scrcpy: missing\n'
    failed=1
  fi

  if command -v qrencode >/dev/null 2>&1; then
    printf 'qrencode: %s\n' "$(command -v qrencode)"
  else
    printf 'qrencode: missing (required only for wireless-pair-qr)\n'
  fi

  if command -v adb >/dev/null 2>&1; then
    printf '\nConnected devices:\n'
    adb devices
  fi

  if [ "$failed" -ne 0 ]; then
    cat <<'MSG'

Install dependencies on Ubuntu:
  sudo apt update
  sudo apt install android-tools-adb scrcpy qrencode avahi-utils
MSG
    exit 1
  fi
}

mirror() {
  need_scrcpy
  require_device

  local args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-audio) args+=(--no-audio) ;;
      --stay-awake) args+=(--stay-awake) ;;
      --turn-screen-off) args+=(--turn-screen-off) ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown mirror option: $1" ;;
    esac
    shift
  done

  exec scrcpy "${args[@]}"
}

mirror_off() {
  need_scrcpy
  require_device

  local args=(--turn-screen-off --stay-awake --disable-screensaver)
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --no-audio) args+=(--no-audio) ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown mirror-off option: $1" ;;
    esac
    shift
  done

  enable_screen_off_mode
  trap 'disable_screen_off_mode' EXIT
  scrcpy "${args[@]}"
}

start_session() {
  need_scrcpy
  require_device
  ensure_state

  local mode="normal"
  local args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --screen-off|--turn-screen-off)
        mode="screen-off"
        args+=(--turn-screen-off --stay-awake --disable-screensaver)
        ;;
      --no-audio) args+=(--no-audio) ;;
      --stay-awake) args+=(--stay-awake) ;;
      -h|--help) usage; exit 0 ;;
      *) die "unknown start option: $1" ;;
    esac
    shift
  done

  local id device started log_path pid
  id="phone-$(date +%Y%m%d-%H%M%S)"
  device="$(current_device)"
  started="$(date '+%Y-%m-%d %H:%M:%S')"
  log_path="$(logs_dir)/${id}.log"

  if [ "$mode" = "screen-off" ]; then
    enable_screen_off_mode
  fi

  nohup scrcpy "${args[@]}" > "$log_path" 2>&1 < /dev/null &
  pid="$!"

  sleep 0.3
  if ! pid_alive "$pid"; then
    if [ "$mode" = "screen-off" ]; then
      disable_screen_off_mode
    fi
    printf 'scrcpy exited immediately. Log:\n' >&2
    sed -n '1,120p' "$log_path" >&2
    exit 1
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$pid" "$mode" "$device" "$started" "$log_path" >> "$(sessions_file)"
  printf 'started session %s pid=%s mode=%s device=%s\n' "$id" "$pid" "$mode" "$device"
}

start_off_session() {
  start_session --screen-off "$@"
}

list_sessions() {
  cleanup_sessions

  if [ ! -s "$(sessions_file)" ]; then
    printf 'no active phone-control sessions\n'
    return 0
  fi

  printf '%-22s %-8s %-11s %-22s %s\n' "SESSION" "PID" "MODE" "DEVICE" "STARTED"
  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    printf '%-22s %-8s %-11s %-22s %s\n' "$id" "$pid" "$mode" "$device" "$started"
  done < "$(sessions_file)"
}

stop_session() {
  [ "$#" -eq 1 ] || die "usage: phone-control stop SESSION_ID_OR_PID"

  local row id pid mode device started log_path
  row="$(find_session "$1")" || die "session not found: $1"
  IFS=$'\t' read -r id pid mode device started log_path <<< "$row"

  if pid_alive "$pid"; then
    kill "$pid"
  fi

  remove_session "$id"
  if [ "$mode" = "screen-off" ] && ! has_screen_off_session; then
    disable_screen_off_mode
  fi
  printf 'stopped session %s pid=%s\n' "$id" "$pid"
}

stop_all_sessions() {
  cleanup_sessions

  local stopped=0
  local stopped_screen_off=0
  while IFS=$'\t' read -r id pid mode device started log_path; do
    [ -n "${id:-}" ] || continue
    if pid_alive "$pid"; then
      kill "$pid"
      stopped=$((stopped + 1))
      if [ "$mode" = "screen-off" ]; then
        stopped_screen_off=1
      fi
    fi
  done < "$(sessions_file)"

  : > "$(sessions_file)"
  if [ "$stopped_screen_off" -eq 1 ] || [ -f "$(screen_timeout_file)" ]; then
    disable_screen_off_mode
  fi
  printf 'stopped %s session(s)\n' "$stopped"
}

show_logs() {
  [ "$#" -eq 1 ] || die "usage: phone-control logs SESSION_ID_OR_PID"

  local row id pid mode device started log_path
  row="$(find_session "$1")" || die "session not found: $1"
  IFS=$'\t' read -r id pid mode device started log_path <<< "$row"

  sed -n '1,200p' "$log_path"
}

screenshot() {
  require_device
  local out="${1:-phone-screenshot-$(date +%Y%m%d-%H%M%S).png}"
  adb exec-out screencap -p > "$out"
  printf 'saved screenshot: %s\n' "$out"
}

record() {
  require_device
  local out="${1:-phone-recording-$(date +%Y%m%d-%H%M%S).mp4}"
  printf 'Recording. Press Ctrl+C to stop.\n'
  scrcpy --record "$out"
}

apps() {
  require_device
  adb shell pm list packages | sed 's/^package://'
}

open_app() {
  require_device
  [ "$#" -eq 1 ] || die "usage: phone-control open PACKAGE"
  adb shell monkey -p "$1" -c android.intent.category.LAUNCHER 1
}

run_key() {
  require_device
  [ "$#" -eq 1 ] || die "usage: phone-control key KEYCODE_OR_NAME"
  adb shell input keyevent "$(keycode "$1")"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    -h|--help|"") usage ;;
    doctor) shift; doctor "$@" ;;
    devices) shift; need_adb; adb devices -l "$@" ;;
    mirror) shift; mirror "$@" ;;
    mirror-off) shift; mirror_off "$@" ;;
    start) shift; start_session "$@" ;;
    start-off) shift; start_off_session "$@" ;;
    sessions) shift; list_sessions "$@" ;;
    stop) shift; stop_session "$@" ;;
    stop-all) shift; stop_all_sessions "$@" ;;
    logs) shift; show_logs "$@" ;;
    wireless-pair-qr)
      shift
      [ "$#" -eq 0 ] || die "usage: phone-control wireless-pair-qr"
      wireless_pair_qr
      ;;
    wireless-pair)
      shift
      need_adb
      [ "$#" -eq 2 ] || die "usage: phone-control wireless-pair HOST:PAIR_PORT PAIR_CODE"
      adb pair "$1" "$2"
      ;;
    wireless-connect)
      shift
      need_adb
      [ "$#" -eq 1 ] || die "usage: phone-control wireless-connect HOST:ADB_PORT"
      adb connect "$1"
      ;;
    screenshot) shift; screenshot "$@" ;;
    record) shift; record "$@" ;;
    install)
      shift
      require_device
      [ "$#" -eq 1 ] || die "usage: phone-control install APK"
      adb install "$1"
      ;;
    push)
      shift
      require_device
      [ "$#" -eq 2 ] || die "usage: phone-control push SRC PHONE_DEST"
      adb push "$1" "$2"
      ;;
    pull)
      shift
      require_device
      [ "$#" -eq 2 ] || die "usage: phone-control pull PHONE_SRC DEST"
      adb pull "$1" "$2"
      ;;
    apps) shift; apps "$@" ;;
    open) shift; open_app "$@" ;;
    key) shift; run_key "$@" ;;
    shell)
      shift
      require_device
      [ "${1:-}" = "--" ] && shift
      adb shell "$@"
      ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
